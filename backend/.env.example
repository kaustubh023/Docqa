# Django Settings
SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.com,your-server-ip
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# PostgreSQL Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=docqa_db
DB_USER=docqa_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Security / proxy (recommended for Nginx + HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/api/users/token/refresh/
REFRESH_COOKIE_SECURE=True
REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_MAX_AGE=604800

# AI API Keys
GROQ_API_KEY=your-groq-api-key
GOOGLE_API_KEY=your-google-api-key

# Optional: force embedding/model cache to a writable directory
# DOCQA_EMBEDDINGS_CACHE_DIR=/absolute/path/to/writable/cache
